<style>
  .search-btn{
    background-color: #fe424d;
    color:#fff;
    border-radius:10px;
    padding:0 1rem;
  }

  .search-btn:hover{
    background-color: #fe424d;
    color:#fff;
  }

  .search-btn i{
    margin-right:0.5rem;
  }

  .search-input{
    border-radius:10px;
    padding:0.5rem 1rem;
    font-size:1rem;
  }

  /* mobile spacing fix */
  @media (max-width: 768px){
    .navbar-nav{
      gap: 6px;
    }

    .nav-link{
      padding: 4px 0;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
  <div class="container-fluid">

    <!-- Brand -->
    <a class="navbar-brand" href="/listings">
      <i class="fa-regular fa-compass"></i>
    </a>

    <!-- Toggle -->
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup">
      <span class="navbar-toggler-icon"></span>
    </button>

    <!-- NAV CONTENT -->
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">

      <!-- LEFT -->
      <div class="navbar-nav me-auto">
        <a class="nav-link" href="/listings">Explore</a>
      </div>

      <!-- RIGHT -->
      <div class="navbar-nav ms-auto d-flex flex-column flex-md-row align-items-start align-items-md-center">

        <a class="nav-link" href="/listings/new">Airbnb your home</a>

        <% const currUserSafe = (typeof currUser !== 'undefined') ? currUser : null; %>

        <% if(!currUserSafe){ %>
          <a class="nav-link" href="/signup"><b>Sign Up</b></a>
          <a class="nav-link" href="/login"><b>Log in</b></a>
        <% } %>

        <% if(currUserSafe){ %>
          <a class="nav-link" href="/logout"><b>Logout</b></a>
        <% } %>

      </div>

    </div>
  </div>
</nav>