<style>
  @media (max-width: 768px) {

    .navbar-nav {
        text-align: center;
    }

    .navbar-nav .nav-link {
        padding: 0.7rem 0;
    }

    .navbar form {
        width: 100%;
        margin: 10px 0;
    }

    .search-input {
        width: 100%;
        padding: 0.5rem 1rem;
    }

    .search-btn {
        white-space: nowrap;
    }
}
</style>




<div class="collapse navbar-collapse" id="navbarNavAltMarkup">

    <div class="navbar-nav me-auto">
        <a class="nav-link" href="/listings">Explore</a>
    </div>

    <form class="d-flex my-2 my-md-0 mx-auto" action="/listings" method="GET">
        <input class="form-control me-2 search-input" type="search" placeholder="Search">
        <button class="btn search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>Search
        </button>
    </form>

    <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new">Airbnb your home</a>

        <% const currUserSafe = (typeof currUser !== 'undefined') ? currUser : null; %>

        <% if(!currUserSafe){ %>
            <a class="nav-link" href="/signup"><b>Sign Up</b></a>
            <a class="nav-link" href="/login"><b>Log In</b></a>
        <% } else { %>
            <a class="nav-link" href="/logout"><b>Logout</b></a>
        <% } %>
    </div>

</div>