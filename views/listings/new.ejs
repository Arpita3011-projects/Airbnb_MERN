<% layout("/layouts/boilerplate") %>
<% const listingData = typeof listing !== 'undefined' ? listing : {}; %>
<div class="row">
  <div class="col-8 offset-2">
<div class="container mt-5">
  <br>
  <h3>Create a New Listing</h3>
  <% if (typeof error !== 'undefined') { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>
  <form method="POST" action="/listings"  novalidate class="needs-validation">
    <div class="mb-3">
      <label for="title" class="form-label">Title</label>
      <input id="title" name="listing[title]" value="<%= listingData.title || '' %>" class="form-control" placeholder="enter title" required>
      <div class="valid-feedback">
      Looks good!
    </div>
    <div class="invalid-feedback">
        Please choose a title.
      </div>
    </div>

    <div class="mb-3">
      <label for="description" class="form-label">Description</label>
        <textarea id="description" name="listing[description]" class="form-control" placeholder="enter description" required><%= listingData.description || '' %></textarea>
    <div class="valid-feedback">
      Looks good!
    </div>
    <div class="invalid-feedback">
        Please Enter a description.
      </div>
    </div>

    <div class="mb-3">
      <label for="image" class="form-label">Image Link</label>
      <input id="image" name="listing[image][url]" value="<%= listingData.image?.url || '' %>" class="form-control" placeholder="enter image URL">
    </div>
<div class="row">
    <div class="mb-3 col-md-4">
      <label for="price" class="form-label">Price</label>
      <input id="price" name="listing[price]" type="text" inputmode="decimal" value="<%= listingData.price || '' %>" class="form-control" placeholder="enter price" required >
      <div class="valid-feedback">
      Looks good!
    </div>
    <div class="invalid-feedback">
        Please enter a valid price.
      </div>
    </div>

    <div class="mb-3 col-md-8">
      <label for="country" class="form-label">Country</label>
      <input id="country" name="listing[country]" value="<%= listingData.country || '' %>" class="form-control" placeholder="enter country" required>
    </div>
    <div class="invalid-feedback">
        Please choose a country.
      </div>
      <div class="valid-feedback">
      Looks good!
    </div>
    </div>

    <div class="mb-3">
      <label for="location" class="form-label">Location</label>
      <input id="location" name="listing[location]" value="<%= listingData.location || '' %>" class="form-control" placeholder="enter location" required>
    <div class="invalid-feedback">
        Please choose a valid location.
      </div>
      <div class="valid-feedback">
      Looks good!
    </div>
    </div>
    <button type="submit" class="btn btn-dark add-btn mb-3">Add</button>
  </form>
</div>
</div>
</div>