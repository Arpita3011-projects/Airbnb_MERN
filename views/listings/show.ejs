<% layout("/layouts/boilerplate") %> 
<div class="row mt-3">
<div class="col-8 offset-3">
    <h1>Listing details</h1></div>
    <div class="card col-6 offset-3 show-card">
  <img src="<%= listing.image && listing.image.url ? listing.image.url : listing.image %>" class="card-img-top show-img" alt="listing_image">
  <div class="card-body">
    <p class="card-text"><b><%=listing.title%></b></p><br>
    <p class="card-text"><%=listing.description%></p><br>
    <p class="card-text">&#8377;<%=listing.price.toLocaleString("en-IN")%></p><br>
    <p class="card-text"><%=listing.location%></p><br>
    <p class="card-text"><%=listing.country%></p><br> 

  </div>
</div>
</div>
<br>
<div class="btns"><br>
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark col-1 offset-3 edit-btn">Edit </a>
    
     <form method="POST" action="/listings/<%=listing._id%>?_method=DELETE">
        <button class="btn btn-dark offset-5 delete-btn">Delete </button>
    </form>
    </div>
   
</div>

